BOT_TOKEN=your_telegram_bot_token
# Если переменная не задана, бот сам выберет:
# 1) существующую базу /data/stalker_game.db
# 2) или существующую legacy-базу ./stalker_game.db
# 3) или создаст новую в /data/stalker_game.db
DB_PATH=/data/stalker_game.db
# Файл резервного состояния. Оставь внутри persistent volume.
SNAPSHOT_PATH=/data/stalker_game.backup.json
